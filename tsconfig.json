    "module": "ES2020",
    "lib": ["DOM", "ES2020"],
    "rootDir": "./frontend/src",
    "outDir": "./frontend/src/dist",
    "strict": true,
    "moduleResolution": "bundler"
  },
  "include": [
    "frontend/src/main.ts",
    "frontend/src/dom.ts",
    "frontend/src/firebase-config.ts",
    "frontend/src/onboarding.ts"
